# Scout — AI Configuration (all optional, static scan works without any keys)

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...

# Ollama (local, free, no key needed)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# Default AI provider: anthropic | openai | ollama | none
# SCOUT_AI_PROVIDER=none
